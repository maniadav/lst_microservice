# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=lst_service

# Feature flags
# "local" = read image semantics from local JSON file
# "mongodb" = read from MongoDB assessment_images collection
SEMANTICS_SOURCE=local
LOCAL_SEMANTICS_PATH=app/data/sample_semantics.json

# Set to true to save assessment results to MongoDB
SAVE_RESULTS_TO_DB=false

# HuggingFace (required for Pyannote speaker diarization)
HF_TOKEN=your_hf_token_here

# WhisperX
WHISPER_MODEL_NAME=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Security
API_KEY=

# Logging
LOG_LEVEL=INFO

# Audio
MAX_UPLOAD_SIZE_MB=50

